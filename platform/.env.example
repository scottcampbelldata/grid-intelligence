# --- Postgres (TimescaleDB) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=grid_intel
PGUSER=grid_app
PGPASSWORD=replace_me

# --- API keys ---
# EIA (free): register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=replace_me
# ENTSO-E (free): register at https://transparency.entsoe.eu/ and request an API key by email
ENTSOE_API_KEY=replace_me
# NOAA Weather API: no key required, just a User-Agent contact
NOAA_USER_AGENT=grid-intelligence-platform (contact@example.com)

# --- Service ports ---
GRIDINTEL_API_PORT=8787

# --- Behavior ---
GRIDINTEL_LOG_LEVEL=INFO
GRIDINTEL_BACKFILL_HOURS=168
GRIDINTEL_FORECAST_HORIZON_H=24
