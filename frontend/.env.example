# Copy to .env.local and adjust. NEXT_PUBLIC_* vars are inlined at build time
# and are public - never put secrets here.

# Base URL of the Grid Intelligence FastAPI backend (no trailing slash).
#   local mock / SSH tunnel:  http://localhost:8787
#   public Droplet API:       https://api.grid.scottcampbell.io
NEXT_PUBLIC_API_BASE=http://localhost:8787
